#!/usr/bin/env bash
# ro — meta-CLI for ronan-skills.
#
# `ro context` resolves which credential profile is active for the current
# working directory using a three-tier precedence chain (highest first):
#
#   0. $RO_CONTEXT environment variable        (one-shot override for a single shell)
#   1. .ro-context.local in cwd or ancestor    (gitignored, contributor override)
#   2. .ro-context in cwd or ancestor          (committed, repo's declared context)
#   3. cwd-glob rule in ~/.claude/contexts.json
#   4. default in ~/.claude/contexts.json
#
# Plus a manual override:
#
#   `ro context use <name>` sets active=<name> in contexts.json (sticks until
#   `ro context auto` clears it). Used when cwd doesn't tell the right story
#   (e.g. you're editing a credential file outside any repo).
#
# Skills that need credentials should source via:
#   set -a; source "$(ro context env)"; set +a
#
# Backwards compat: ~/.claude/.env stays as a symlink to whichever context's
# env file is currently active. Skills that haven't migrated to `ro context
# env` keep working unchanged.
#
# Layout (all under ~/.claude/, no split with ~/.config/):
#   ~/.claude/.env                 → symlink to ~/.claude/.env.<active>
#   ~/.claude/.env.<name>          → real file per context (mode 600)
#   ~/.claude/contexts.json        → rules + default + manual override

set -euo pipefail

ENV_DIR="${HOME}/.claude"
ENV_LINK="${ENV_DIR}/.env"
CONFIG_FILE="${ENV_DIR}/contexts.json"
CI_CONFIG_FILE="${ENV_DIR}/ci-policy.json"

# Legacy state from v1 (gets migrated on `ro context init` or first resolve)
LEGACY_ACTIVE="${HOME}/.config/ro/active-context"

# ────────────────────────────────────────────────────────────────────────────
# Helpers
# ────────────────────────────────────────────────────────────────────────────

die() {
  echo "ro: $*" >&2
  exit 1
}

require_jq() {
  command -v jq >/dev/null 2>&1 || die "jq is required (brew install jq)"
}

# Find a file walking up from cwd to $HOME (inclusive). Echoes the absolute
# path or returns 1 if not found. Doesn't traverse above $HOME.
find_ancestor_file() {
  local name="$1"
  local dir
  dir="$(pwd -P)"
  while [[ -n "$dir" ]]; do
    if [[ -f "$dir/$name" ]]; then
      echo "$dir/$name"
      return 0
    fi
    [[ "$dir" == "$HOME" || "$dir" == "/" ]] && return 1
    dir="$(dirname "$dir")"
  done
  return 1
}

read_first_line() {
  # First non-blank, non-comment line of a file, trimmed.
  awk 'NF && $1 !~ /^#/ { gsub(/^[[:space:]]+|[[:space:]]+$/, "", $0); print; exit }' "$1"
}

# Expand ~ and $HOME in a glob pattern so it can be matched against absolute paths.
expand_pattern() {
  local p="$1"
  p="${p/#\~/$HOME}"
  p="${p//\$HOME/$HOME}"
  echo "$p"
}

# Bash-style glob match. Handles `**` as "anything including /".
match_glob() {
  local pattern="$1"
  local path="$2"
  pattern="$(expand_pattern "$pattern")"
  # Translate ** → * for shell glob (a single * already matches /)
  # Use [[ with extglob: enable shopt
  shopt -s extglob globstar 2>/dev/null || true
  # shellcheck disable=SC2053
  [[ "$path" == $pattern ]]
}

ensure_config_exists() {
  if [[ -f "$CONFIG_FILE" ]]; then
    return 0
  fi
  require_jq
  mkdir -p "$ENV_DIR"
  # Migrate from v1: default = "personal" (the convention), and `active` is
  # only carried over if the v1 user had explicitly switched away from
  # personal. Avoids the foot-gun where the migration silently makes the
  # last-switched context the new default.
  local default="personal"
  local active="null"
  if [[ -f "$LEGACY_ACTIVE" ]]; then
    local legacy
    legacy="$(read_first_line "$LEGACY_ACTIVE" || true)"
    if [[ -n "$legacy" && "$legacy" != "personal" ]]; then
      active="\"${legacy}\""
    fi
  fi
  cat > "$CONFIG_FILE" <<EOF
{
  "default": "${default}",
  "active": ${active},
  "rules": []
}
EOF
  chmod 600 "$CONFIG_FILE"
}

read_config() {
  ensure_config_exists
  require_jq
  jq -r "$1" "$CONFIG_FILE"
}

write_config() {
  require_jq
  ensure_config_exists
  local tmp
  tmp="$(mktemp)"
  jq "$1" "$CONFIG_FILE" > "$tmp" && mv "$tmp" "$CONFIG_FILE"
  chmod 600 "$CONFIG_FILE"
}

env_file_for() {
  local name="$1"
  echo "${ENV_DIR}/.env.${name}"
}

update_symlink() {
  local name="$1"
  local target
  target="$(env_file_for "$name")"
  if [[ ! -f "$target" ]]; then
    echo "ro: warning — env file does not exist: $target" >&2
    return 1
  fi
  if [[ -e "$ENV_LINK" && ! -L "$ENV_LINK" ]]; then
    echo "ro: ${ENV_LINK} is a regular file, refusing to clobber. Move it aside (mv ${ENV_LINK} ${ENV_LINK}.legacy) and retry." >&2
    return 1
  fi
  ln -sfn "$target" "$ENV_LINK"
}

# ────────────────────────────────────────────────────────────────────────────
# Resolution
# ────────────────────────────────────────────────────────────────────────────

# Returns (source, name) on stdout, one per line, in this order: source then name.
# Source is one of: env, active, .ro-context.local, .ro-context, rule, default.
resolve_with_source() {
  if [[ -n "${RO_CONTEXT:-}" ]]; then
    echo "env"
    echo "$RO_CONTEXT"
    return 0
  fi

  ensure_config_exists

  local active
  active="$(read_config '.active // empty')"
  if [[ -n "$active" ]]; then
    echo "active"
    echo "$active"
    return 0
  fi

  local found
  if found="$(find_ancestor_file ".ro-context.local")"; then
    echo ".ro-context.local ($found)"
    read_first_line "$found"
    return 0
  fi
  if found="$(find_ancestor_file ".ro-context")"; then
    echo ".ro-context ($found)"
    read_first_line "$found"
    return 0
  fi

  local cwd
  cwd="$(pwd -P)"
  # Walk rules in declared order, first match wins.
  local rule_count
  rule_count="$(read_config '.rules | length')"
  for ((i = 0; i < rule_count; i++)); do
    local pattern context
    pattern="$(read_config ".rules[$i][0]")"
    context="$(read_config ".rules[$i][1]")"
    if match_glob "$pattern" "$cwd"; then
      echo "rule (${pattern})"
      echo "$context"
      return 0
    fi
  done

  echo "default"
  read_config '.default'
}

# ────────────────────────────────────────────────────────────────────────────
# Sub-commands
# ────────────────────────────────────────────────────────────────────────────

usage() {
  cat <<'USAGE'
ro — switch credential profiles for ronan-skills

Resolution (highest priority first):
  $RO_CONTEXT env var   →   contexts.json:active   →   .ro-context.local
  →   .ro-context   →   contexts.json:rules (cwd globs)   →   contexts.json:default

Usage:
  ro context show              # print the resolved context name
  ro context where             # print where the resolution came from
  ro context env               # print absolute path of the resolved env file (use this in skills)
  ro context list              # list available contexts (env.<name> files)
  ro context use <name>        # pin active=<name> in contexts.json (manual override)
  ro context auto              # clear the active override, fall back to cwd resolution
  ro context init              # first-time setup; migrates from v1 layout if present
  ro context add-rule <pattern> <name>   # append a cwd-glob rule
  ro context diff <a> <b>      # compare keys (no values) between two contexts
  ro context path              # alias for `ro context env` (legacy)

Skills should source via:
  set -a; source "$(ro context env)"; set +a

Per-repo override (committed):     .ro-context           # one line, just the context name
Per-repo override (gitignored):    .ro-context.local

CI policy (skip remote CI, trust the local gate):
  ro ci show                   # print the resolved CI policy (JSON)
  ro ci get <key>              # print one value (remoteCI | localGate | mergeOnLocalPass | autoDeploy)
  ro ci where                  # show which files contributed + the resolved policy
  ro ci init                   # write the global ~/.claude/ci-policy.json with defaults

  Resolution (later wins): default < ~/.claude/ci-policy.json
    < .ro-ci.json (committed) < .ro-ci.local.json (gitignored)

Worktree locking (coordinate multiple agents on one repo):
  ro worktree acquire          # lock the first free slot; prints the path to cd into
  ro worktree release [slot]   # free the slot when pushed/done (defaults to cwd's)
  ro worktree status           # show the slot pool + who holds what
  ro worktree reap             # free slots idle past TTL (RO_WT_TTL, default 6h)

  Slots: "main" (primary checkout) then Greek worktrees (beta, gamma…), created
  on demand. Lock file: <main>/.ro/worktree-locks.json (gitignored).
  Set RO_AGENT to label yourself; always `release` when you've pushed.
USAGE
}

cmd_show() {
  resolve_with_source | tail -1
}

cmd_where() {
  local out
  out="$(resolve_with_source)"
  local source name
  source="$(echo "$out" | head -1)"
  name="$(echo "$out" | tail -1)"
  printf 'context = %s   (resolved from: %s)\n' "$name" "$source"
}

cmd_env() {
  env_file_for "$(cmd_show)"
}

cmd_list() {
  local active
  active="$(cmd_show)"
  shopt -s nullglob
  for f in "${ENV_DIR}"/.env.*; do
    local base name marker
    base="$(basename "$f")"
    case "$base" in
      *.bak.*|*.swp|*.swo) continue ;;
    esac
    name="${base#.env.}"
    marker="  "
    [[ "$name" == "$active" ]] && marker="* "
    echo "${marker}${name}"
  done
}

cmd_use() {
  local name="${1:-}"
  [[ -z "$name" ]] && die "missing context name. Available:$(printf '\n')$(cmd_list)"
  local target
  target="$(env_file_for "$name")"
  [[ -f "$target" ]] || die "no env file at ${target}. Create it first (umask 077; touch ${target})."
  write_config ".active = \"${name}\""
  update_symlink "$name"
  echo "Switched to: ${name}  (override; clear with 'ro context auto')"
  echo "  ${ENV_LINK} -> ${target}"
}

cmd_auto() {
  write_config '.active = null'
  local resolved
  resolved="$(cmd_show)"
  update_symlink "$resolved" || true
  echo "Cleared override. Active context now resolves dynamically: ${resolved}"
}

cmd_init() {
  ensure_config_exists
  if [[ ! -f "$(env_file_for personal)" ]]; then
    umask 077
    cat > "$(env_file_for personal)" <<'TEMPLATE'
# ============================================================
# Claude Code — Global Environment Variables (personal context)
# ============================================================
# Edit values; do not commit. Add API tokens for the skills you use.
# Switch contexts with: ro context use <name>

# --- Cloudflare ---
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

# --- Sentry ---
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=

# --- PostHog ---
# POSTHOG_PERSONAL_API_KEY=
# POSTHOG_HOST=https://eu.posthog.com
# POSTHOG_INGEST_HOST=https://eu.i.posthog.com
TEMPLATE
    chmod 600 "$(env_file_for personal)"
    echo "Created template: $(env_file_for personal)"
  fi
  if [[ ! -L "$ENV_LINK" && ! -e "$ENV_LINK" ]]; then
    ln -sfn "$(env_file_for personal)" "$ENV_LINK"
    echo "Linked: $ENV_LINK -> $(env_file_for personal)"
  fi
  echo "Done. Edit $(env_file_for personal) and add credentials."
  echo "To add another context: cp $(env_file_for personal) $(env_file_for work) && ro context use work"
  echo "To add cwd-glob auto-resolution: ro context add-rule '~/Github-Simplicity/**' simplicity"
}

cmd_add_rule() {
  local pattern="${1:-}"
  local name="${2:-}"
  [[ -z "$pattern" || -z "$name" ]] && die "usage: ro context add-rule <pattern> <context-name>"
  write_config ".rules += [[\"${pattern}\", \"${name}\"]]"
  echo "Added rule: ${pattern} → ${name}"
}

cmd_diff() {
  local a="${1:-}" b="${2:-}"
  [[ -z "$a" || -z "$b" ]] && die "usage: ro context diff <a> <b>"
  local fa fb
  fa="$(env_file_for "$a")"
  fb="$(env_file_for "$b")"
  for f in "$fa" "$fb"; do
    [[ -f "$f" ]] || die "missing $f"
  done
  local tmp_a tmp_b
  tmp_a="$(mktemp)" tmp_b="$(mktemp)"
  trap 'rm -f "$tmp_a" "$tmp_b"' EXIT
  grep -E '^[A-Za-z_][A-Za-z0-9_]*=' "$fa" | cut -d= -f1 | sort -u > "$tmp_a"
  grep -E '^[A-Za-z_][A-Za-z0-9_]*=' "$fb" | cut -d= -f1 | sort -u > "$tmp_b"
  diff -u --label "${a}/keys" --label "${b}/keys" "$tmp_a" "$tmp_b" || true
}

# ────────────────────────────────────────────────────────────────────────────
# CI policy — "skip remote CI, trust the local gate" config
#
# Resolution (later wins): built-in default < global ~/.claude/ci-policy.json
#   < committed .ro-ci.json (ancestor) < gitignored .ro-ci.local.json (ancestor)
#
# Keys:
#   remoteCI         "skip" | "require"  — wait on GitHub Actions, or not
#   localGate        bool  — pre-push runs the full local CI (the real gate)
#   mergeOnLocalPass bool  — open PR then squash-merge once local gate passed
#   autoDeploy       bool  — deploy straight after merge
# ────────────────────────────────────────────────────────────────────────────

ci_default_json() {
  cat <<'JSON'
{
  "remoteCI": "require",
  "localGate": true,
  "mergeOnLocalPass": true,
  "autoDeploy": true
}
JSON
}

resolve_ci_policy() {
  require_jq
  local g="{}" c="{}" o="{}" f
  [[ -f "$CI_CONFIG_FILE" ]] && g="$(cat "$CI_CONFIG_FILE")"
  f="$(find_ancestor_file '.ro-ci.json' || true)";       [[ -n "$f" ]] && c="$(cat "$f")"
  f="$(find_ancestor_file '.ro-ci.local.json' || true)"; [[ -n "$f" ]] && o="$(cat "$f")"
  jq -n \
    --argjson d "$(ci_default_json)" \
    --argjson g "$g" --argjson c "$c" --argjson o "$o" \
    '$d * $g * $c * $o'
}

cmd_ci_show() { resolve_ci_policy; }

cmd_ci_get() {
  local key="${1:-}"
  [[ -z "$key" ]] && die "usage: ro ci get <key>"
  resolve_ci_policy | jq -r --arg k "$key" '.[$k] // empty'
}

cmd_ci_where() {
  local f
  echo "default:    built-in"
  echo "global:     ${CI_CONFIG_FILE}$( [[ -f "$CI_CONFIG_FILE" ]] && echo '  (present)' || echo '  (absent)')"
  f="$(find_ancestor_file '.ro-ci.json' || true)";       echo "committed:  ${f:-none}"
  f="$(find_ancestor_file '.ro-ci.local.json' || true)"; echo "override:   ${f:-none}"
  echo "---"
  echo "resolved:"
  resolve_ci_policy
}

cmd_ci_init() {
  require_jq
  mkdir -p "$ENV_DIR"
  if [[ -f "$CI_CONFIG_FILE" ]]; then
    echo "ro: ${CI_CONFIG_FILE} already exists, leaving it"
    return 0
  fi
  ci_default_json > "$CI_CONFIG_FILE"
  echo "ro: wrote ${CI_CONFIG_FILE}"
}

# ────────────────────────────────────────────────────────────────────────────
# Worktree locking — coordinate multiple agents on one repo
#
# Lock file lives in the PRIMARY checkout at .ro/worktree-locks.json (gitignored).
# Slots: "main" (the primary checkout) + Greek-suffixed worktrees (beta, gamma…).
# An agent `acquire`s the first free slot (creating the next Greek worktree if
# none free), works there on its own branch, then `release`s when pushed/done.
# Stale busy slots (older than TTL or explicitly past their work) are reaped.
# ────────────────────────────────────────────────────────────────────────────

WT_TTL_SECONDS="${RO_WT_TTL:-21600}"   # 6h default
WT_GREEK="beta gamma delta epsilon zeta eta theta"

wt_now()   { date -u +%Y-%m-%dT%H:%M:%SZ; }
wt_epoch() { date +%s; }
wt_agent() { echo "${RO_AGENT:-agent-$$@$(hostname -s 2>/dev/null || echo host)}"; }

# Primary checkout path (first entry of `git worktree list`).
wt_main_dir() {
  git worktree list --porcelain 2>/dev/null | awk '/^worktree /{print $2; exit}'
}

wt_lock_file() {
  local main_dir; main_dir="$(wt_main_dir)" || return 1
  [[ -z "$main_dir" ]] && return 1
  echo "${main_dir}/.ro/worktree-locks.json"
}

# Echo "slot<TAB>path" for every checkout. main first, then -<greek> worktrees.
wt_slot_paths() {
  local main_dir; main_dir="$(wt_main_dir)"
  local repo; repo="$(basename "$main_dir")"
  echo "main	${main_dir}"
  git worktree list --porcelain 2>/dev/null | awk '/^worktree /{print $2}' | tail -n +2 | while read -r p; do
    local base; base="$(basename "$p")"
    case "$base" in
      "${repo}-"*) echo "${base#${repo}-}	${p}" ;;
    esac
  done
}

wt_ensure_lock() {
  require_jq
  local lf; lf="$(wt_lock_file)" || die "not inside a git repo"
  mkdir -p "$(dirname "$lf")"
  [[ -f "$lf" ]] || echo '{"slots":{}}' > "$lf"
  # Keep .ro/ out of git.
  local main_dir; main_dir="$(wt_main_dir)"
  local gi="${main_dir}/.gitignore"
  if [[ -f "$gi" ]] && ! grep -qxF '.ro/' "$gi"; then
    printf '\n# ro agent coordination state\n.ro/\n' >> "$gi"
  fi
  echo "$lf"
}

# Free any busy slot whose acquired_epoch is older than TTL.
wt_reap() {
  local lf; lf="$(wt_ensure_lock)"
  local now; now="$(wt_epoch)"
  local tmp; tmp="$(mktemp)"
  jq --argjson now "$now" --argjson ttl "$WT_TTL_SECONDS" '
    .slots |= with_entries(
      if (.value.status=="busy") and ((.value.acquired_epoch // 0) < ($now-$ttl))
      then .value.status="free" | .value.stale=true else . end)
  ' "$lf" > "$tmp" && mv "$tmp" "$lf"
}

cmd_wt_status() {
  local lf; lf="$(wt_ensure_lock)"
  wt_reap
  echo "lock: $lf"
  local main_dir; main_dir="$(wt_main_dir)"
  echo "slots (path → state):"
  wt_slot_paths | while IFS="	" read -r slot path; do
    local st; st="$(jq -r --arg s "$slot" '.slots[$s].status // "free"' "$lf")"
    local who; who="$(jq -r --arg s "$slot" '.slots[$s].agent // ""' "$lf")"
    printf "  %-8s %-50s %s %s\n" "$slot" "$path" "$st" "$who"
  done
}

cmd_wt_acquire() {
  local lf; lf="$(wt_ensure_lock)"
  wt_reap
  local main_dir repo agent now ep
  main_dir="$(wt_main_dir)"; repo="$(basename "$main_dir")"
  agent="$(wt_agent)"; now="$(wt_now)"; ep="$(wt_epoch)"

  # 1) First free existing slot (main, then beta, gamma…).
  local chosen_slot="" chosen_path=""
  while IFS="	" read -r slot path; do
    local st; st="$(jq -r --arg s "$slot" '.slots[$s].status // "free"' "$lf")"
    if [[ "$st" != "busy" ]]; then chosen_slot="$slot"; chosen_path="$path"; break; fi
  done < <(wt_slot_paths)

  # 2) None free → create the next Greek worktree.
  if [[ -z "$chosen_slot" ]]; then
    local used; used="$(wt_slot_paths | cut -f1)"
    for g in $WT_GREEK; do
      if ! echo "$used" | grep -qx "$g"; then chosen_slot="$g"; break; fi
    done
    [[ -z "$chosen_slot" ]] && die "worktree pool exhausted ($WT_GREEK)"
    chosen_path="$(dirname "$main_dir")/${repo}-${chosen_slot}"
    local base="HEAD"
    git -C "$main_dir" rev-parse --verify -q main      >/dev/null && base="main"
    git -C "$main_dir" rev-parse --verify -q origin/main >/dev/null && base="origin/main"
    git -C "$main_dir" worktree add "$chosen_path" -b "wt/${chosen_slot}-${ep}" "$base" >&2 \
      || die "worktree add failed"
  fi

  local tmp; tmp="$(mktemp)"
  jq --arg s "$chosen_slot" --arg p "$chosen_path" --arg a "$agent" \
     --arg t "$now" --argjson e "$ep" '
     .slots[$s] = {path:$p, status:"busy", agent:$a, acquired_at:$t, acquired_epoch:$e, pushed:false}
  ' "$lf" > "$tmp" && mv "$tmp" "$lf"

  echo "$chosen_path"   # stdout = the path to cd into (everything else is stderr)
  echo "ro: acquired '${chosen_slot}' for ${agent}" >&2
}

cmd_wt_release() {
  local lf; lf="$(wt_ensure_lock)"
  local target="${1:-}"
  if [[ -z "$target" ]]; then
    # Resolve the slot from cwd's worktree path.
    local here; here="$(git rev-parse --show-toplevel 2>/dev/null)"
    while IFS="	" read -r slot path; do
      [[ "$path" == "$here" ]] && { target="$slot"; break; }
    done < <(wt_slot_paths)
  fi
  [[ -z "$target" ]] && die "could not determine slot to release (pass a slot name)"
  local tmp; tmp="$(mktemp)"
  jq --arg s "$target" '
    if .slots[$s] then .slots[$s].status="free" | .slots[$s].pushed=true else . end
  ' "$lf" > "$tmp" && mv "$tmp" "$lf"
  echo "ro: released '${target}'" >&2
}

# ────────────────────────────────────────────────────────────────────────────
# Dispatch
# ────────────────────────────────────────────────────────────────────────────

case "${1:-}" in
  context)
    case "${2:-show}" in
      show|resolve)             cmd_show ;;
      where)                    cmd_where ;;
      env|path)                 cmd_env ;;
      list)                     cmd_list ;;
      use)                      cmd_use "${3:-}" ;;
      auto)                     cmd_auto ;;
      init)                     cmd_init ;;
      add-rule|add_rule|rule)   cmd_add_rule "${3:-}" "${4:-}" ;;
      diff)                     cmd_diff "${3:-}" "${4:-}" ;;
      -h|--help|help)           usage ;;
      *) echo "ro: unknown context sub-command: ${2}" >&2; usage; exit 2 ;;
    esac
    ;;
  ci)
    case "${2:-show}" in
      show|resolve)             cmd_ci_show ;;
      get)                      cmd_ci_get "${3:-}" ;;
      where)                    cmd_ci_where ;;
      init)                     cmd_ci_init ;;
      -h|--help|help)           usage ;;
      *) echo "ro: unknown ci sub-command: ${2}" >&2; usage; exit 2 ;;
    esac
    ;;
  worktree|wt)
    case "${2:-status}" in
      acquire)                  cmd_wt_acquire ;;
      release|done)             cmd_wt_release "${3:-}" ;;
      status|list)              cmd_wt_status ;;
      reap)                     wt_reap && cmd_wt_status ;;
      -h|--help|help)           usage ;;
      *) echo "ro: unknown worktree sub-command: ${2}" >&2; usage; exit 2 ;;
    esac
    ;;
  -h|--help|help|"")             usage ;;
  *) echo "ro: unknown command: ${1}" >&2; usage; exit 2 ;;
esac
