{
  "name": "{{APP_NAME}}",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "vitest run",
    "test:unit": "vitest run",
    "deploy": "wrangler deploy",
    "deploy:dry": "wrangler deploy --dry-run",
    "db:generate": "drizzle-kit generate --config drizzle/neon/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle/neon/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config drizzle/neon/drizzle.config.ts",
    "quality": "pnpm run format && pnpm run lint && pnpm run build && pnpm run test",
    "prepare": "husky"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@tanstack/react-router": "1.169.2",
    "@tanstack/react-start": "1.167.65",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.16.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.37.0",
    "@cloudflare/workers-types": "^4.20250509.0",
    "@commitlint/cli": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/router-plugin": "^1.167.35",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6",
    "wrangler": "^4.91.0"
  },
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd"
    ]
  }
}
