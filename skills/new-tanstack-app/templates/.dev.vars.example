# Local dev environment variables. Copy to .dev.vars (gitignored) and fill in values.
# Production values are set as wrangler secrets, not in this file.

# Neon (Postgres) connection string.
# Get this from https://console.neon.tech after creating a project.
# Format: postgresql://<user>:<password>@<host>/<dbname>?sslmode=require
NEON_DATABASE_URL=postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/myapp?sslmode=require

# Add other secrets below as needed, e.g.:
# CLERK_SECRET_KEY=sk_test_...
# ANTHROPIC_API_KEY=sk-ant-...
